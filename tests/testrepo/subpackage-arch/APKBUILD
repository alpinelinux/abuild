pkgname=${TESTNAME-test-pkgname}
pkgver=${TESTPKGVER-1.0}
pkgrel=0
pkgdesc="Dummy subpackage arch"
url="https://gitlab.alpinelinux.org/alpine/aports"
arch="noarch"
license="MIT"
subpackages="$pkgname-$TESTSUBARCH:_sub:$TESTSUBARCH"
builddir="$srcdir"
options="!check"

package() {
	mkdir -p "$pkgdir"
}

_sub() {
	mkdir -p "$subpkgdir"
}
