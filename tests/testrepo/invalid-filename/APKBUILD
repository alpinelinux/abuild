pkgname=invalid-filename
pkgver=1.0
pkgrel=0
pkgdesc="Dummy test package that fails to build"
url="https://gitlab.alpinelinux.org/alpine/aports"
arch="noarch"
license="MIT"
builddir="$srcdir"
options="!check"

build() {
	touch $'bad\nfile'
}

package() {
	mkdir -p "$pkgdir"
	cp -R * "$pkgdir"/
}

