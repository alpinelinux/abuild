# defaults are in @sharedir@/default.conf
#
# uncomment line below to enable colors
#USE_COLORS=1

# uncomment line below to enable ccache support.
#USE_CCACHE=1

# where downloaded files are stored
#SRCDEST=${XDG_CACHE_HOME:-$HOME/.cache}/abuild

# uncomment line below to store built packages in other location
# The package will be stored as $REPODEST/$repo/$arch/$pkgname-$pkgver-r$pkgrel.apk
# where $repo is the name of the parent directory of $startdir.
#REPODEST=${XDG_DATA_HOME:-$HOME/.local/share}/abuild

# included in build .apk files and used by abuild-keygen to derive default filename
#PACKAGER="Your Name <your@email.address>"

# default contributor/maintainer for generated APKBUILDs
#MAINTAINER="$PACKAGER"

# what to clean up after a successful build
#CLEANUP="srcdir bldroot pkgdir deps"

# what to cleanup after a failed build
#ERROR_CLEANUP="bldroot deps"

# uncomment to use global cache directories for Go and Cargo
#GOCACHE="${XDG_CACHE_HOME:-$HOME/.cache}"/go-build
#GOMODCACHE=${GOPATH:-$HOME/go}/pkg/mod
#CARGO_HOME=$HOME/.cargo

# uncomment to avoid creating .orig files when patches don't align
#patch_args_cfg="--no-backup-if-mismatch"

# uncomment to disable SOURCE_DATE_EPOCH retrieval and fasten up the build process
#SOURCE_DATE_EPOCH=0
